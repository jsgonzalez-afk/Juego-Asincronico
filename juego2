<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>⚔️ Realm of Async — RPG</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=MedievalSharp&family=Cinzel:wght@400;700;900&family=Crimson+Text:ital,wght@0,400;0,600;1,400&display=swap');

  :root {
    --gold: #f0c040;
    --gold-dim: #a07820;
    --blood: #8b1a1a;
    --crimson: #c0392b;
    --emerald: #1a6b3a;
    --sapphire: #1a3a7a;
    --parchment: #f5e6c8;
    --ink: #1a0a00;
    --shadow: #0a0500;
    --bg: #080400;
    --panel: rgba(15, 8, 0, 0.92);
    --border: #3a2800;
    --hp-green: #2ecc71;
    --hp-red: #e74c3c;
    --mp-blue: #3498db;
    --xp-gold: #f39c12;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    background: var(--bg);
    color: var(--parchment);
    font-family: 'Crimson Text', serif;
    font-size: 18px;
    min-height: 100vh;
    overflow-x: hidden;
    background-image:
      radial-gradient(ellipse at 20% 80%, rgba(80,20,0,0.3) 0%, transparent 50%),
      radial-gradient(ellipse at 80% 20%, rgba(20,40,80,0.2) 0%, transparent 50%),
      url("data:image/svg+xml,%3Csvg width='60' height='60' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M0 0h60v60H0z' fill='none'/%3E%3Ccircle cx='1' cy='1' r='0.5' fill='rgba(240,192,64,0.08)'/%3E%3C/svg%3E");
  }

  #app {
    max-width: 960px;
    margin: 0 auto;
    padding: 20px;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  /* ═══ HEADER ═══ */
  .game-title {
    text-align: center;
    font-family: 'Cinzel', serif;
    font-size: clamp(1.8rem, 5vw, 3rem);
    font-weight: 900;
    color: var(--gold);
    text-shadow: 0 0 30px rgba(240,192,64,0.5), 0 2px 4px black;
    letter-spacing: 4px;
    padding: 12px 0 4px;
    position: relative;
  }
  .game-title::after {
    content: '';
    display: block;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--gold), transparent);
    margin: 8px auto 0;
    width: 60%;
  }
  .game-subtitle {
    text-align: center;
    color: var(--gold-dim);
    font-style: italic;
    font-size: 1rem;
    letter-spacing: 2px;
  }

  /* ═══ PANELS ═══ */
  .panel {
    background: var(--panel);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 16px;
    position: relative;
    box-shadow: 0 4px 20px rgba(0,0,0,0.6), inset 0 1px 0 rgba(240,192,64,0.1);
  }
  .panel::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 4px;
    pointer-events: none;
    background: linear-gradient(135deg, rgba(240,192,64,0.03) 0%, transparent 60%);
  }

  .panel-title {
    font-family: 'Cinzel', serif;
    font-size: 0.8rem;
    letter-spacing: 3px;
    color: var(--gold-dim);
    text-transform: uppercase;
    margin-bottom: 12px;
    border-bottom: 1px solid var(--border);
    padding-bottom: 8px;
  }

  /* ═══ CHARACTER SELECTION ═══ */
  #char-select { animation: fadeIn 0.5s ease; }

  .class-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 14px;
    margin-top: 8px;
  }

  .class-card {
    background: rgba(20,10,0,0.8);
    border: 2px solid var(--border);
    border-radius: 6px;
    padding: 18px;
    cursor: pointer;
    transition: all 0.25s ease;
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .class-card::before {
    content: '';
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 0.25s;
    border-radius: 4px;
  }
  .class-card.warrior::before { background: radial-gradient(ellipse, rgba(180,30,30,0.2), transparent 70%); }
  .class-card.mage::before   { background: radial-gradient(ellipse, rgba(30,80,180,0.2), transparent 70%); }
  .class-card.rogue::before  { background: radial-gradient(ellipse, rgba(30,150,80,0.2), transparent 70%); }
  .class-card.paladin::before{ background: radial-gradient(ellipse, rgba(200,160,30,0.25), transparent 70%); }
  .class-card:hover { border-color: var(--gold); transform: translateY(-3px); box-shadow: 0 8px 24px rgba(0,0,0,0.5); }
  .class-card:hover::before { opacity: 1; }

  .class-icon { font-size: 2.8rem; margin-bottom: 8px; display: block; filter: drop-shadow(0 2px 4px black); }
  .class-name { font-family: 'Cinzel', serif; font-size: 1.1rem; font-weight: 700; color: var(--gold); margin-bottom: 6px; }
  .class-desc { font-size: 0.85rem; color: #c0a880; line-height: 1.5; margin-bottom: 10px; font-style: italic; }
  .class-stats { font-size: 0.78rem; color: #907060; line-height: 1.8; }
  .stat-bar-mini {
    display: flex; align-items: center; gap: 6px; justify-content: center; margin: 3px 0;
  }
  .stat-bar-mini span:first-child { width: 30px; text-align: right; }
  .mini-bar { height: 5px; background: #1a0800; border-radius: 3px; flex: 1; max-width: 80px; overflow: hidden; }
  .mini-bar-fill { height: 100%; border-radius: 3px; transition: width 0.4s; }

  /* ═══ HUD ═══ */
  #hud {
    display: none;
    grid-template-columns: 1fr auto 1fr;
    gap: 12px;
    align-items: start;
  }
  #hud.active { display: grid; }

  .hud-entity {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .entity-name {
    font-family: 'Cinzel', serif;
    font-weight: 700;
    font-size: 1rem;
    color: var(--gold);
    text-shadow: 0 0 10px rgba(240,192,64,0.3);
  }
  .entity-class { font-size: 0.8rem; color: var(--gold-dim); font-style: italic; }
  .entity-level { font-size: 0.75rem; color: #907060; }

  .stat-row { display: flex; flex-direction: column; gap: 5px; }
  .stat-label { font-size: 0.72rem; letter-spacing: 1px; color: #706050; display: flex; justify-content: space-between; }
  .bar-track {
    height: 10px; background: #0a0500; border-radius: 5px; overflow: hidden;
    border: 1px solid rgba(255,255,255,0.05);
  }
  .bar-fill { height: 100%; border-radius: 5px; transition: width 0.6s ease; position: relative; }
  .bar-fill.hp { background: linear-gradient(90deg, #1a6b1a, var(--hp-green)); box-shadow: 0 0 8px rgba(46,204,113,0.4); }
  .bar-fill.mp { background: linear-gradient(90deg, #1a3a6b, var(--mp-blue)); box-shadow: 0 0 8px rgba(52,152,219,0.4); }
  .bar-fill.xp { background: linear-gradient(90deg, #6b4a1a, var(--xp-gold)); }

  .vs-badge {
    font-family: 'Cinzel', serif;
    font-size: 1.4rem;
    font-weight: 900;
    color: var(--crimson);
    text-align: center;
    text-shadow: 0 0 20px rgba(192,57,43,0.6);
    padding-top: 8px;
    align-self: center;
  }

  .enemy-side { text-align: right; }

  /* ═══ BATTLE LOG ═══ */
  #log-panel { flex: 1; }
  #log {
    height: 240px;
    overflow-y: auto;
    padding: 8px 4px;
    display: flex;
    flex-direction: column;
    gap: 4px;
    scrollbar-width: thin;
    scrollbar-color: var(--border) transparent;
  }
  #log::-webkit-scrollbar { width: 4px; }
  #log::-webkit-scrollbar-thumb { background: var(--border); border-radius: 2px; }

  .log-entry {
    padding: 4px 8px;
    border-radius: 3px;
    font-size: 0.92rem;
    line-height: 1.5;
    animation: slideIn 0.2s ease;
    border-left: 3px solid transparent;
  }
  .log-entry.player  { border-left-color: var(--gold); color: #e8d5a0; }
  .log-entry.enemy   { border-left-color: var(--crimson); color: #e8a090; }
  .log-entry.system  { border-left-color: var(--sapphire); color: #90a8e0; font-style: italic; }
  .log-entry.success { border-left-color: var(--hp-green); color: #90e0a8; }
  .log-entry.warning { border-left-color: var(--xp-gold); color: #e0c890; }
  .log-entry.critical { border-left-color: #ff6b6b; color: #ff9b9b; font-weight: 600; }

  /* ═══ ACTIONS ═══ */
  #actions-panel { }
  .action-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
    gap: 10px;
  }
  .action-btn {
    background: rgba(20,10,0,0.9);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 12px 8px;
    color: var(--parchment);
    font-family: 'Crimson Text', serif;
    font-size: 0.95rem;
    cursor: pointer;
    transition: all 0.2s ease;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    position: relative;
    overflow: hidden;
  }
  .action-btn::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(240,192,64,0.0), rgba(240,192,64,0.05));
    opacity: 0;
    transition: opacity 0.2s;
  }
  .action-btn:hover:not(:disabled) { border-color: var(--gold); color: var(--gold); transform: translateY(-2px); box-shadow: 0 4px 15px rgba(0,0,0,0.5); }
  .action-btn:hover:not(:disabled)::after { opacity: 1; }
  .action-btn:disabled { opacity: 0.35; cursor: not-allowed; }
  .action-btn:active:not(:disabled) { transform: translateY(0); }
  .action-icon { font-size: 1.6rem; }
  .action-name { font-size: 0.88rem; font-weight: 600; }
  .action-cost { font-size: 0.72rem; color: var(--mp-blue); opacity: 0.8; }

  /* ═══ INVENTORY / SHOP ═══ */
  .item-row {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 8px 10px;
    border-radius: 4px;
    border: 1px solid transparent;
    transition: border-color 0.2s;
    cursor: pointer;
  }
  .item-row:hover { border-color: var(--border); }
  .item-icon { font-size: 1.4rem; }
  .item-name { flex: 1; font-size: 0.9rem; }
  .item-count { font-size: 0.8rem; color: var(--gold-dim); }

  /* ═══ BOTTOM ROW ═══ */
  .bottom-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px;
  }

  /* ═══ SCREEN OVERLAYS ═══ */
  .overlay {
    position: fixed; inset: 0;
    background: rgba(0,0,0,0.85);
    display: flex; align-items: center; justify-content: center;
    z-index: 100;
    animation: fadeIn 0.3s ease;
  }
  .overlay-box {
    background: #0f0800;
    border: 2px solid var(--gold);
    border-radius: 8px;
    padding: 40px;
    text-align: center;
    max-width: 440px;
    box-shadow: 0 0 60px rgba(240,192,64,0.2);
    animation: scaleIn 0.4s ease;
  }
  .overlay-title { font-family: 'Cinzel', serif; font-size: 2rem; font-weight: 900; margin-bottom: 12px; }
  .overlay-title.victory { color: var(--gold); text-shadow: 0 0 20px rgba(240,192,64,0.5); }
  .overlay-title.defeat  { color: var(--crimson); text-shadow: 0 0 20px rgba(192,57,43,0.5); }
  .overlay-desc { color: #c0a880; margin: 10px 0 24px; line-height: 1.6; font-size: 1rem; }
  .overlay-rewards { color: var(--gold); margin-bottom: 20px; font-size: 0.95rem; line-height: 1.8; }

  /* ═══ BUTTONS ═══ */
  .btn {
    background: linear-gradient(135deg, #3a2000, #2a1500);
    border: 1px solid var(--gold-dim);
    border-radius: 4px;
    color: var(--gold);
    font-family: 'Cinzel', serif;
    font-size: 0.9rem;
    letter-spacing: 1px;
    padding: 10px 24px;
    cursor: pointer;
    transition: all 0.2s;
    text-transform: uppercase;
  }
  .btn:hover { background: linear-gradient(135deg, #5a3000, #3a2000); border-color: var(--gold); box-shadow: 0 0 15px rgba(240,192,64,0.2); }
  .btn.danger { border-color: var(--crimson); color: var(--crimson); background: linear-gradient(135deg, #200a0a, #180505); }
  .btn.danger:hover { background: linear-gradient(135deg, #401010, #280808); }

  /* ═══ DUNGEON MAP ═══ */
  .floor-indicator {
    font-family: 'Cinzel', serif;
    text-align: center;
    font-size: 0.85rem;
    color: var(--gold-dim);
    letter-spacing: 2px;
  }
  .floor-dots {
    display: flex; gap: 6px; justify-content: center; margin-top: 8px; flex-wrap: wrap;
  }
  .floor-dot {
    width: 12px; height: 12px; border-radius: 50%;
    border: 1px solid var(--border);
    background: #1a0a00;
    transition: all 0.3s;
  }
  .floor-dot.done { background: var(--gold-dim); border-color: var(--gold); }
  .floor-dot.current { background: var(--crimson); border-color: #ff6b6b; box-shadow: 0 0 8px rgba(255,107,107,0.5); animation: pulse 1.5s infinite; }
  .floor-dot.boss { border-color: var(--crimson); }

  /* ═══ ANIMATIONS ═══ */
  @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
  @keyframes slideIn { from { opacity: 0; transform: translateX(-10px); } to { opacity: 1; transform: translateX(0); } }
  @keyframes scaleIn { from { opacity: 0; transform: scale(0.9); } to { opacity: 1; transform: scale(1); } }
  @keyframes pulse { 0%,100% { box-shadow: 0 0 8px rgba(255,107,107,0.5); } 50% { box-shadow: 0 0 16px rgba(255,107,107,0.9); } }
  @keyframes shake { 0%,100% { transform: translateX(0); } 20%,60% { transform: translateX(-6px); } 40%,80% { transform: translateX(6px); } }
  @keyframes glow { 0%,100% { text-shadow: 0 0 10px rgba(240,192,64,0.3); } 50% { text-shadow: 0 0 25px rgba(240,192,64,0.7); } }

  .shake { animation: shake 0.4s ease; }
  .level-up-flash { animation: glow 0.6s ease 3; }

  .loading-dots::after {
    content: '';
    animation: dots 1.2s steps(4, end) infinite;
  }
  @keyframes dots {
    0%   { content: ''; }
    25%  { content: '.'; }
    50%  { content: '..'; }
    75%  { content: '...'; }
  }

  /* ═══ STATUS EFFECTS ═══ */
  .status-effects { display: flex; gap: 6px; flex-wrap: wrap; margin-top: 6px; }
  .status-badge {
    font-size: 0.7rem; padding: 2px 7px; border-radius: 10px;
    border: 1px solid;
    display: flex; align-items: center; gap: 3px;
    animation: fadeIn 0.3s ease;
  }
  .status-badge.poison { border-color: #6b3d8b; color: #c090e0; background: rgba(107,61,139,0.2); }
  .status-badge.burn   { border-color: #8b3d1a; color: #e09050; background: rgba(139,61,26,0.2); }
  .status-badge.shield { border-color: #3d6b8b; color: #90c0e0; background: rgba(61,107,139,0.2); }
  .status-badge.stun   { border-color: #8b8b1a; color: #e0e050; background: rgba(139,139,26,0.2); }
  .status-badge.regen  { border-color: #1a6b3a; color: #60c080; background: rgba(26,107,58,0.2); }

  /* ═══ TOOLTIP ═══ */
  [data-tip] { position: relative; }
  [data-tip]:hover::after {
    content: attr(data-tip);
    position: absolute;
    bottom: 110%; left: 50%; transform: translateX(-50%);
    background: #1a0a00;
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 6px 10px;
    font-size: 0.78rem;
    color: #c0a880;
    white-space: nowrap;
    z-index: 50;
    pointer-events: none;
    font-family: 'Crimson Text', serif;
  }

  /* ═══ RESPONSIVE ═══ */
  @media (max-width: 640px) {
    #hud { grid-template-columns: 1fr 1fr; }
    .vs-badge { display: none; }
    .bottom-row { grid-template-columns: 1fr; }
  }
</style>
</head>
<body>
<div id="app">

  <div>
    <div class="game-title">⚔️ Realm of Async ⚔️</div>
    <div class="game-subtitle">~ Un Dungeon RPG en JavaScript ~</div>
  </div>

  <!-- CHARACTER SELECT -->
  <div class="panel" id="char-select">
    <div class="panel-title">◈ Elige tu clase de héroe ◈</div>
    <div class="class-grid" id="class-grid"></div>
  </div>

  <!-- HUD -->
  <div class="panel" id="hud">
    <div class="hud-entity" id="player-hud">
      <div>
        <div class="entity-name" id="p-name">—</div>
        <div class="entity-class" id="p-class">—</div>
        <div class="entity-level" id="p-level">Nivel 1</div>
      </div>
      <div class="stat-row">
        <div class="stat-label"><span>❤️ HP</span><span id="p-hp-txt">—</span></div>
        <div class="bar-track"><div class="bar-fill hp" id="p-hp-bar" style="width:100%"></div></div>
      </div>
      <div class="stat-row">
        <div class="stat-label"><span>💧 MP</span><span id="p-mp-txt">—</span></div>
        <div class="bar-track"><div class="bar-fill mp" id="p-mp-bar" style="width:100%"></div></div>
      </div>
      <div class="stat-row">
        <div class="stat-label"><span>✨ XP</span><span id="p-xp-txt">—</span></div>
        <div class="bar-track"><div class="bar-fill xp" id="p-xp-bar" style="width:0%"></div></div>
      </div>
      <div class="status-effects" id="p-status"></div>
    </div>

    <div class="vs-badge">⚔<br>VS<br>⚔</div>

    <div class="hud-entity enemy-side" id="enemy-hud">
      <div>
        <div class="entity-name" id="e-name">—</div>
        <div class="entity-class" id="e-class">—</div>
        <div class="entity-level" id="e-level">—</div>
      </div>
      <div class="stat-row">
        <div class="stat-label"><span id="e-hp-txt">—</span><span>❤️ HP</span></div>
        <div class="bar-track"><div class="bar-fill hp" id="e-hp-bar" style="width:100%"></div></div>
      </div>
      <div class="status-effects" id="e-status" style="justify-content:flex-end"></div>
    </div>
  </div>

  <!-- FLOOR MAP -->
  <div class="panel" id="floor-panel" style="display:none">
    <div class="floor-indicator" id="floor-text">Piso 1 de 8</div>
    <div class="floor-dots" id="floor-dots"></div>
  </div>

  <!-- BATTLE LOG -->
  <div class="panel" id="log-panel" style="display:none">
    <div class="panel-title">◈ Crónica de Batalla ◈</div>
    <div id="log"></div>
  </div>

  <!-- ACTIONS -->
  <div class="panel" id="actions-panel" style="display:none">
    <div class="panel-title">◈ Acciones ◈</div>
    <div class="action-grid" id="action-grid"></div>
  </div>

  <!-- BOTTOM ROW -->
  <div class="bottom-row" id="bottom-row" style="display:none">
    <!-- INVENTORY -->
    <div class="panel">
      <div class="panel-title">◈ Inventario ◈</div>
      <div id="inventory-list"></div>
    </div>
    <!-- STATS -->
    <div class="panel">
      <div class="panel-title">◈ Atributos ◈</div>
      <div id="attr-list" style="font-size:0.88rem;line-height:2;"></div>
    </div>
  </div>

</div>

<!-- OVERLAYS -->
<div id="overlay" class="overlay" style="display:none">
  <div class="overlay-box">
    <div class="overlay-title" id="ov-title"></div>
    <div class="overlay-desc" id="ov-desc"></div>
    <div class="overlay-rewards" id="ov-rewards"></div>
    <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap">
      <button class="btn" id="ov-btn1"></button>
      <button class="btn danger" id="ov-btn2" style="display:none"></button>
    </div>
  </div>
</div>

<script>
// ═══════════════════════════════════════════════════════
//  UTILIDADES ASÍNCRONAS
// ═══════════════════════════════════════════════════════

/** Espera N milisegundos (asincronismo puro con Promise) */
const delay = ms => new Promise(resolve => setTimeout(resolve, ms));

/** Genera número entero aleatorio [min, max] */
const rand = (min, max) => Math.floor(Math.random() * (max - min + 1)) + min;

/** Genera flotante aleatorio [0, 1) */
const chance = p => Math.random() < p;

// ═══════════════════════════════════════════════════════
//  CLASE BASE: Entity (POO, Clase, instancia, get/set)
// ═══════════════════════════════════════════════════════

class Entity {
  #name;          // campo privado
  #maxHp;
  #hp;
  #statusEffects; // array de objetos

  constructor(name, hp) {
    this.#name = name;
    this.#maxHp = hp;
    this.#hp = hp;
    this.#statusEffects = [];
  }

  // GET / SET
  get name()   { return this.#name; }
  get hp()     { return this.#hp; }
  get maxHp()  { return this.#maxHp; }
  get isDead() { return this.#hp <= 0; }
  get statuses(){ return [...this.#statusEffects]; }

  set hp(val) {
    this.#hp = Math.max(0, Math.min(val, this.#maxHp));
  }
  set maxHp(val) {
    this.#maxHp = val;
    this.#hp = Math.min(this.#hp, val);
  }

  get hpPercent() { return (this.#hp / this.#maxHp) * 100; }

  addStatus(effect) {
    const existing = this.#statusEffects.find(e => e.name === effect.name);
    if (existing) { existing.turns = effect.turns; return; }
    this.#statusEffects.push({ ...effect });
  }

  removeStatus(name) {
    this.#statusEffects = this.#statusEffects.filter(e => e.name !== name);
  }

  hasStatus(name) { return this.#statusEffects.some(e => e.name === name); }

  tickStatuses() {
    const msgs = [];
    this.#statusEffects = this.#statusEffects.filter(eff => {
      if (eff.name === 'poison') {
        const dmg = Math.floor(this.#maxHp * 0.06);
        this.hp = this.#hp - dmg;
        msgs.push({ text: `☠️ ${this.#name} sufre ${dmg} de veneno.`, type: 'enemy' });
      }
      if (eff.name === 'burn') {
        const dmg = Math.floor(this.#maxHp * 0.04);
        this.hp = this.#hp - dmg;
        msgs.push({ text: `🔥 ${this.#name} sufre ${dmg} por quemadura.`, type: 'enemy' });
      }
      if (eff.name === 'regen') {
        const heal = Math.floor(this.#maxHp * 0.05);
        this.hp = this.#hp + heal;
        msgs.push({ text: `💚 ${this.#name} regenera ${heal} HP.`, type: 'success' });
      }
      eff.turns--;
      return eff.turns > 0;
    });
    return msgs;
  }

  // Método polimórfico base
  toString() { return `${this.#name} [${this.#hp}/${this.#maxHp} HP]`; }
}

