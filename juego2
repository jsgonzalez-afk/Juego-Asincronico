// ═══════════════════════════════════════════════════════

class Player extends Entity {
  static XP_TABLE = [0, 50, 130, 250, 420, 650, 950, 1320, 1760, 9999]; // static
  static BASE_STATS = { warrior: { atk:18, def:12, mag:5, spd:8 },
                         mage:    { atk:7,  def:6,  mag:22, spd:10 },
                         rogue:   { atk:14, def:8,  mag:8,  spd:16 },
                         paladin: { atk:12, def:16, mag:10, spd:7  } };

  #mp; #maxMp; #xp; #level; #className; #atk; #def; #mag; #spd;
  inventory; gold;

  constructor(name, className) {
    const hpMap = { warrior:120, mage:80, rogue:95, paladin:110 };
    const mpMap = { warrior:40,  mage:100, rogue:60, paladin:80 };
    super(name, hpMap[className]);
    this.#className = className;
    this.#maxMp = mpMap[className];
    this.#mp = this.#maxMp;
    this.#xp = 0;
    this.#level = 1;
    const s = Player.BASE_STATS[className];
    this.#atk = s.atk; this.#def = s.def;
    this.#mag = s.mag; this.#spd = s.spd;
    this.inventory = [
      { id:'potion', name:'Poción', icon:'🧪', count:3, desc:'Restaura 40 HP' },
      { id:'elixir', name:'Elixir',  icon:'💧', count:1, desc:'Restaura 30 MP' },
    ];
    this.gold = 20;
  }

  // GET-SET de MP y nivel
  get mp()     { return this.#mp; }
  get maxMp()  { return this.#maxMp; }
  get level()  { return this.#level; }
  get className() { return this.#className; }
  get atk() { return this.#atk; }
  get def() { return this.#def; }
  get mag() { return this.#mag; }
  get spd() { return this.#spd; }
  get xp()     { return this.#xp; }
  get xpNext() { return Player.XP_TABLE[this.#level] || 9999; }
  get xpPercent() { return Math.min((this.#xp / this.xpNext) * 100, 100); }
  get mpPercent() { return (this.#mp / this.#maxMp) * 100; }

  set mp(val)  { this.#mp = Math.max(0, Math.min(val, this.#maxMp)); }

  /** Añade XP y retorna si subió de nivel */
  gainXP(amount) {
    this.#xp += amount;
    if (this.#xp >= this.xpNext && this.#level < 9) {
      this.#xp -= this.xpNext;
      this.#level++;
      this.#levelUp();
      return true;
    }
    return false;
  }

  #levelUp() {
    const gains = { warrior:{hp:18,mp:5,atk:3,def:2,mag:1,spd:1},
                    mage:   {hp:10,mp:18,atk:1,def:1,mag:4,spd:1},
                    rogue:  {hp:14,mp:8,atk:2,def:1,mag:1,spd:3},
                    paladin:{hp:16,mp:10,atk:2,def:3,mag:2,spd:1} };
    const g = gains[this.#className];
    this.maxHp = this.maxHp + g.hp;
    this.hp = this.hp + g.hp;
    this.#maxMp += g.mp; this.#mp += g.mp;
    this.#atk += g.atk; this.#def += g.def;
    this.#mag += g.mag; this.#spd += g.spd;
  }

  useItem(id) {
    const item = this.inventory.find(i => i.id === id);
    if (!item || item.count <= 0) return null;
    item.count--;
    if (id === 'potion') { const h = 40; this.hp = this.hp + h; return `🧪 Usas una Poción y recuperas ${h} HP.`; }
    if (id === 'elixir') { const m = 30; this.mp = this.mp + m; return `💧 Usas un Élixir y recuperas ${m} MP.`; }
    return null;
  }

  calcDamage(skill, enemy) {
    const base = skill.type === 'physical' ? this.#atk : this.#mag;
    const mult = skill.power;
    const raw = Math.floor(base * mult * (rand(85,115) / 100));
    const reduced = skill.type === 'physical'
      ? Math.max(1, raw - Math.floor(enemy.def * 0.5))
      : Math.max(1, raw - Math.floor(enemy.def * 0.2));
    const crit = chance(0.12 + this.#spd * 0.005);
    return { dmg: crit ? Math.floor(reduced * 1.7) : reduced, crit };
  }
}

// ═══════════════════════════════════════════════════════
//  CLASE: Enemy (Herencia de Entity)
