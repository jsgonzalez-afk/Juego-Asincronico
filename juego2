const game = {
  player: null,
  enemy: null,
  currentFloor: 1,
  playerSkills: [],
  battleActive: false,
  playerTurn: true,

  // ─── INICIO ───────────────────────────────────────

  init() {
    UI.init();
    this.renderCharSelect();
  },

  renderCharSelect() {
    document.getElementById('char-select').style.display='';
    const grid = document.getElementById('class-grid');
    grid.innerHTML = CLASS_DATA.map(c => `
      <div class="class-card ${c.id}" onclick="game.selectClass('${c.id}')">
        <span class="class-icon">${c.icon}</span>
        <div class="class-name">${c.name}</div>
        <div class="class-desc">${c.desc}</div>
        <div>
          ${['ATK','DEF','MAG','VEL'].map((stat,i)=>`
            <div class="stat-bar-mini">
              <span>${stat}</span>
              <div class="mini-bar">
                <div class="mini-bar-fill" style="width:${c.barW[i]}%;background:${['#c0392b','#2980b9','#8e44ad','#27ae60'][i]}"></div>
              </div>
            </div>`).join('')}
        </div>
      </div>`).join('');
  },

  selectClass(className) {
    const name = ['Aranor','Lyria','Kael','Theron'][Math.floor(Math.random()*4)];
    this.player = new Player(name, className);
    this.playerSkills = CLASS_DATA.find(c=>c.id===className).skills;
    this.currentFloor = 1;
    document.getElementById('char-select').style.display='none';
    document.getElementById('hud').classList.add('active');
    document.getElementById('floor-panel').style.display='';
    document.getElementById('log-panel').style.display='';
    document.getElementById('actions-panel').style.display='';
    document.getElementById('bottom-row').style.display='';
    this.startDungeon();
  },

  // ─── DUNGEON LOOP (asincronismo) ──────────────────

  async startDungeon() {
    UI.renderFloor(this.currentFloor);
    await UI.log(`🏰 ${this.player.name} entra al Castillo Malachar...`, 'system', 100);
    await delay(300);
    await this.startFloor();
  },

  async startFloor() {
    UI.renderFloor(this.currentFloor);
    const isBoss = this.currentFloor === FLOORS;
    await UI.log(`── Piso ${this.currentFloor} ──`, 'system', 80);

    if (isBoss) {
      await UI.log('👑 ¡El Señor Oscuro te aguarda en la sala del trono!', 'warning', 120);
    } else if (this.currentFloor % 3 === 0) {
      await this.shopEvent();
    }

    // Generar enemigo
    await delay(300);
    this.enemy = this.spawnEnemy();
    UI.updateEnemy(this.enemy);
    await UI.log(`⚠️  ¡Aparece ${this.enemy.icon} ${this.enemy.name}!`, 'enemy', 120);
    await delay(400);
    await this.battleLoop();
  },

  spawnEnemy() {
    const floor = this.currentFloor;
    let pool;
    if (floor === FLOORS) pool = ENEMY_POOL.filter(e=>e.tier==='boss');
    else if (floor === 7)  pool = ENEMY_POOL.filter(e=>e.tier==='miniboss');
    else if (floor >= 5)   pool = ENEMY_POOL.filter(e=>['normal','elite'].includes(e.tier)).slice(3);
    else if (floor >= 3)   pool = ENEMY_POOL.filter(e=>e.tier==='normal').slice(2,6);
    else                   pool = ENEMY_POOL.filter(e=>e.tier==='normal').slice(0,3);
    const data = pool[rand(0, pool.length-1)];
    // Escala el enemigo con el piso
    const scale = 1 + (floor - 1) * 0.12;
    return new Enemy({
      ...data,
      hp:   Math.floor(data.hp * scale),
      atk:  Math.floor(data.atk * scale),
    });
  },

  // ─── BATTLE LOOP ──────────────────────────────────

  async battleLoop() {
    this.battleActive = true;
    UI.updatePlayer(this.player);
    UI.renderActions(this.playerSkills, this.player, false);

    // El jugador tiene más velocidad → ataca primero
    this.playerTurn = this.player.spd >= (this.enemy.atk * 0.5);

    if (!this.playerTurn) {
      await UI.log('⚡ El enemigo actúa primero (más veloz).', 'system');
      await delay(300);
      await this.enemyTurn();
    }
  },

  async doPlayerAction(skillId) {
    if (!this.battleActive || !this.playerTurn) return;
    UI.setActionsDisabled(true);
    this.playerTurn = false;

    const skill = SKILLS[skillId];
    if (skill.cost > 0 && this.player.mp < skill.cost) {
      await UI.log('❌ Maná insuficiente.', 'warning');
      UI.setActionsDisabled(false); this.playerTurn=true; return;
    }
    this.player.mp = this.player.mp - skill.cost;

    await this.executeSkill(skill, this.player, this.enemy);
    UI.updatePlayer(this.player);
    UI.updateEnemy(this.enemy);

    if (this.enemy.isDead) { await this.onEnemyDead(); return; }

    await delay(600);
    await this.enemyTurn();
  },

  async executeSkill(skill, actor, target) {
    const isPlayer = actor instanceof Player;

    if (skill.type === 'physical' || skill.type === 'magic') {
      const { dmg, crit } = isPlayer
        ? actor.calcDamage(skill, target)
        : actor.calcDamage(skill);
      const finalDmg = target.hasStatus('shield') ? Math.floor(dmg * 0.45) : dmg;
      const shieldMsg = target.hasStatus('shield') ? ' (escudo)' : '';

      target.hp = target.hp - finalDmg;
      if (isPlayer) UI.shakeEl('enemy-hud'); else UI.shakeEl('player-hud');

      const critText = crit ? ' ✨ ¡CRÍTICO!' : '';
      const type = isPlayer ? 'player' : (crit ? 'critical' : 'enemy');
      await UI.log(`${actor.name} usa ${skill.icon} ${skill.name}: ${finalDmg} daño${shieldMsg}${critText}`, type);

      // Efectos de habilidad
      if (skill.effect === 'burn')   { target.addStatus({name:'burn',  turns:3}); await UI.log('🔥 ¡Quemadura aplicada!','warning'); }
      if (skill.effect === 'poison') { target.addStatus({name:'poison',turns:3}); await UI.log('☠️  ¡Veneno aplicado!',  'warning'); }
      if (skill.effect === 'stun')   { target.addStatus({name:'stun',  turns:1}); await UI.log('⚡ ¡Aturdido!',         'warning'); }

    } else if (skill.type === 'buff') {
      if (skill.effect === 'shield')    { actor.addStatus({name:'shield',turns:2});    await UI.log(`${actor.name} activa ${skill.icon} ${skill.name}: ¡Escudo activo!`,'success'); }
      if (skill.effect === 'evade')     { actor.addStatus({name:'evade', turns:1});     await UI.log(`${actor.name} entra en posición de evasión.`,'success'); }
      if (skill.effect === 'battleCry') { actor.addStatus({name:'battleCry',turns:2}); await UI.log(`⚔️  ¡${actor.name} lanza un grito de guerra!`,'success'); }

    } else if (skill.type === 'heal') {
      const h = Math.floor(actor.maxHp * 0.28);
      actor.hp = actor.hp + h;
      actor.addStatus({name:'regen',turns:3});
      await UI.log(`💛 ${actor.name} usa Luz Sagrada: recupera ${h} HP + Regeneración.`,'success');
    }
  },

  async enemyTurn() {
    if (this.enemy.isDead) return;

    // Tick de estados enemigo
    const eMsgs = this.enemy.tickStatuses();
    for (const m of eMsgs) { await UI.log(m.text, m.type); await delay(150); }
    if (this.enemy.isDead) { await this.onEnemyDead(); return; }

    // Tick de estados jugador
    const pMsgs = this.player.tickStatuses();
    for (const m of pMsgs) { await UI.log(m.text, m.type); await delay(150); }
    if (this.player.isDead) { await this.onPlayerDead(); return; }

    // Aturdido → pierde turno
    if (this.enemy.hasStatus('stun')) {
      await UI.log(`⚡ ${this.enemy.name} está aturdido y pierde su turno.`, 'system');
      this.enemy.removeStatus('stun');
    } else {
      const action = this.enemy.chooseAction();
      await delay(400);

      if (action.effect === 'stun') {
        this.player.addStatus({name:'stun',turns:1});
        await UI.log(`${this.enemy.icon} ${this.enemy.name} usa ${action.name}: ¡${this.player.name} queda aturdido!`,'enemy');
      } else if (action.effect === 'poison') {
        this.player.addStatus({name:'poison',turns:3});
        const {dmg} = this.enemy.calcDamage(action);
        const finalDmg = this.player.hasStatus('shield') ? Math.floor(dmg*0.45): dmg;
        this.player.hp = this.player.hp - finalDmg;
        await UI.log(`${this.enemy.icon} ${this.enemy.name} usa ${action.name}: ${finalDmg} daño + ☠️ veneno.`,'enemy');
        UI.shakeEl('player-hud');
      } else if (action.effect === 'burn') {
        this.player.addStatus({name:'burn',turns:2});
        const {dmg,crit} = this.enemy.calcDamage(action);
        const finalDmg = this.player.hasStatus('shield') ? Math.floor(dmg*0.45): dmg;
        const evaded = this.player.hasStatus('evade') && chance(0.55);
        if (evaded) {
          await UI.log(`💨 ${this.player.name} evade el ataque de ${this.enemy.name}.`, 'success');
        } else {
          this.player.hp = this.player.hp - finalDmg;
          UI.shakeEl('player-hud');
          await UI.log(`${this.enemy.icon} ${this.enemy.name} usa ${action.name}: ${finalDmg} daño + 🔥 quemadura${crit?'  ¡CRÍTICO!':''}`, crit?'critical':'enemy');
        }
      } else {
        const {dmg,crit} = this.enemy.calcDamage(action);
        const evaded = this.player.hasStatus('evade') && chance(0.55);
        if (evaded) {
          await UI.log(`💨 ${this.player.name} evade el ataque de ${this.enemy.name}.`, 'success');
        } else {
          const reduced = Math.max(1, dmg - Math.floor(this.player.def * 0.4));
          const finalDmg = this.player.hasStatus('shield') ? Math.floor(reduced*0.45) : reduced;
          this.player.hp = this.player.hp - finalDmg;
          UI.shakeEl('player-hud');
          await UI.log(`${this.enemy.icon} ${this.enemy.name} usa ${action.name}: ${finalDmg} daño${crit?' ✨ ¡CRÍTICO!':''}`, crit?'critical':'enemy');
        }
      }

      if (this.player.hasStatus('evade')) this.player.removeStatus('evade');
    }

    UI.updatePlayer(this.player);
    UI.updateEnemy(this.enemy);

    if (this.player.isDead) { await this.onPlayerDead(); return; }

    if (this.player.hasStatus('stun')) {
      await UI.log(`⚡ ${this.player.name} está aturdido y pierde su turno.`,'warning');
      this.player.removeStatus('stun');
      await delay(400);
      await this.enemyTurn();
    } else {
      this.playerTurn = true;
      UI.renderActions(this.playerSkills, this.player, false);
    }
  },

  async useItemInBattle(id) {
    if (!this.battleActive || !this.playerTurn) return;
    const msg = this.player.useItem(id);
    if (!msg) { await UI.log('❌ Sin objetos disponibles.','warning'); return; }
    UI.setActionsDisabled(true); this.playerTurn = false;
    await UI.log(msg, 'success');
    UI.updatePlayer(this.player);
    await delay(400);
    await this.enemyTurn();
  },

  // ─── EVENTS ───────────────────────────────────────

  async onEnemyDead() {
    this.battleActive = false;
    UI.setActionsDisabled(true);
    UI.updateEnemy(this.enemy);
    await UI.log(`🏆 ¡${this.enemy.name} ha sido derrotado!`, 'success', 120);

    const xpGained   = this.enemy.xpReward;
    const goldGained  = this.enemy.goldReward + rand(0, 5);
    this.player.gold += goldGained;
    const leveledUp   = this.player.gainXP(xpGained);

    await delay(300);
    await UI.log(`✨ +${xpGained} XP  💰 +${goldGained} Oro`, 'success');

    if (leveledUp) {
      await delay(400);
      document.getElementById('p-name').classList.add('level-up-flash');
      setTimeout(()=>document.getElementById('p-name').classList.remove('level-up-flash'),1800);
      await UI.log(`🌟 ¡${this.player.name} sube al nivel ${this.player.level}! Atributos mejorados.`, 'warning', 160);
    }

    UI.updatePlayer(this.player);
    await delay(600);

    if (this.currentFloor === FLOORS) {
      await this.onVictory();
    } else {
      UI.showOverlay({
        title: this.currentFloor < FLOORS - 1 ? '⚔️ Batalla Ganada' : '💀 Sub-Jefe Caído',
        titleClass: 'victory',
        desc: `Piso ${this.currentFloor} conquistado. ${this.currentFloor < FLOORS-1 ? '¿Continúas el descenso?' : '¡El trono del mal se acerca!'}`,
        rewards: `✨ +${xpGained} XP  💰 +${goldGained} Oro${leveledUp ? `\n🌟 ¡SUBISTE AL NIVEL ${this.player.level}!` : ''}`,
        btn1: 'Avanzar →',
        cb1: () => { this.currentFloor++; this.startFloor(); }
      });
    }
  },

  async onPlayerDead() {
    this.battleActive = false;
    UI.setActionsDisabled(true);
    await UI.log(`💔 ${this.player.name} ha caído en combate...`, 'enemy', 160);
    await delay(600);
    UI.showOverlay({
      title: '💀 Caído en Batalla',
      titleClass: 'defeat',
      desc: `${this.player.name} fue derrotado en el Piso ${this.currentFloor} por ${this.enemy.name}. Tu leyenda termina aquí... ¿o quizás no?`,
      rewards: `Piso alcanzado: ${this.currentFloor} de ${FLOORS}`,
      btn1: '⚔️ Nueva Partida',
      btn2: '🔁 Reintentar Piso',
      cb1: () => location.reload(),
      cb2: () => {
        // Restaura al jugador con penalización
        this.player.hp = Math.floor(this.player.maxHp * 0.6);
        this.player.mp = Math.floor(this.player.maxMp * 0.6);
        this.startFloor();
      }
    });
  },

  async onVictory() {
    await UI.log('🌟 ¡EL SEÑOR OSCURO HA SIDO DERROTADO! ¡LA LUZ REINA!', 'success', 200);
    await delay(800);
    UI.showOverlay({
      title: '👑 ¡VICTORIA!',
      titleClass: 'victory',
      desc: `¡${this.player.name} ha liberado el reino! Las sombras se disipan y los pueblos celebran tu nombre.`,
      rewards: `🏆 Nivel final: ${this.player.level}\n💰 Oro total: ${this.player.gold}\n⚔️ Clase: ${CLASS_DATA.find(c=>c.id===this.player.className).name}`,
      btn1: '🔄 Jugar de nuevo',
      cb1: () => location.reload()
    });
  },

  // ─── TIENDA (async/await con Promise) ─────────────

  async shopEvent() {
    await UI.log('🏪 Encuentras un mercader errante entre las sombras...', 'system', 140);
    return new Promise(resolve => {
      UI.showOverlay({
        title: '🏪 Mercader',
        titleClass: 'victory',
        desc: '¿Qué deseas comprar antes de continuar?',
        rewards:
          `🧪 Poción de HP (+40) — 15 Oro\n` +
          `💧 Élixir de MP (+30) — 12 Oro\n` +
          `💰 Tu oro: ${this.player.gold}`,
        btn1: '🧪 Comprar Poción (15 Oro)',
        btn2: '💨 Continuar sin comprar',
        cb1: () => {
          if (this.player.gold >= 15) {
            this.player.gold -= 15;
            const p = this.player.inventory.find(i=>i.id==='potion');
            if(p) p.count++; else this.player.inventory.push({id:'potion',name:'Poción',icon:'🧪',count:1,desc:'Restaura 40 HP'});
            UI.log('🧪 Compraste una Poción de HP.','success');
          } else {
            UI.log('❌ No tienes suficiente oro.','warning');
          }
          UI.updatePlayer(this.player);
          resolve();
        },
        cb2: () => resolve()
      });
    });
  },
};

// ═══════════════════════════════════════════════════════
//  ARRANQUE
// ═══════════════════════════════════════════════════════
game.init();
</script>
