class Enemy extends Entity {
  #atk; #def; #xpReward; #goldReward; #tier;
  abilities; icon;

  constructor(data) {
    super(data.name, data.hp);
    this.#atk = data.atk; this.#def = data.def;
    this.#xpReward = data.xp; this.#goldReward = data.gold;
    this.#tier = data.tier || 'normal';
    this.abilities = data.abilities || [];
    this.icon = data.icon || '👾';
  }

  get atk()   { return this.#atk; }
  get def()   { return this.#def; }
  get xpReward() { return this.#xpReward; }
  get goldReward() { return this.#goldReward; }
  get tier()  { return this.#tier; }

  /** IA del enemigo: elige acción aleatoria */
  chooseAction() {
    if (this.abilities.length === 0) return { name: 'Golpe', power: 1.0, effect: null };
    return this.abilities[rand(0, this.abilities.length - 1)];
  }

  calcDamage(action) {
    const raw = Math.floor(this.#atk * action.power * (rand(85,115)/100));
    const crit = chance(0.08);
    return { dmg: crit ? Math.floor(raw * 1.5) : raw, crit };
  }
}

